# --- Server ---
PORT=8000
LOG_LEVEL=info
APP_ENV=development
# Comma-separated list of allowed CORS origins; leave empty to disable cross-origin access.
# Example: CORS_ORIGINS=https://your-landing.example.com,https://www.your-landing.example.com
CORS_ORIGINS=

# --- AI (Gemini) ---
AI_ENABLED=true
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash

# --- Storage (SQLite) ---
SQLITE_PATH=./data/leads.db

# --- Telegram ---
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

